async function analyze() {
  if (!b64) return;


  const btn = document.getElementById('btn-analyze');
  btn.disabled = true;
  btn.innerHTML = '<div class="spinner"></div> ШИНЖИЛЖ БАЙНА...';
  document.getElementById('error-box').style.display = 'none';
  document.getElementById('result').style.display = 'none';

  const API_KEY = document.getElementById('gemini-key').value.trim();
  if (!API_KEY) { showError('Anthropic API Key оруулна уу!'); btn.disabled=false; btn.innerHTML='🔍 AI ШИНЖЛЭХ'; return; }

  const payload = JSON.stringify({
    model: 'claude-sonnet-4-5',
    max_tokens: 2000,
    system: SYSTEM_PROMPT,
    messages: [{
      role: 'user',
      content: [
        { type: 'image', source: { type: 'base64', media_type: 'image/jpeg', data: b64 } },
        { type: 'text', text: 'Analyze this XAUUSD chart using Dow Theory, FVG, BOS/CHOCH, H&S. Return ONLY the JSON.' }
      ]
    }]
  });

  const xhr = new XMLHttpRequest();
  xhr.open('POST', 'https://gtrader-proxy.bayrmagnaiganerdene.workers.dev', true);
  xhr.setRequestHeader('Content-Type', 'application/json');
  xhr.setRequestHeader('x-api-key', API_KEY);
  xhr.setRequestHeader('anthropic-version', '2023-06-01');
  xhr.timeout = 60000;

  xhr.onload = function() {
    try {
      const data = JSON.parse(xhr.responseText);
      if (data.error) { showError('API: ' + (data.error.message || JSON.stringify(data.error))); }
      else {
        const raw = (data.content || []).map(b => b.text || '').join('');
        const m = raw.match(/\{[\s\S]*\}/);
        if (!m) { showError('JSON олдсонгүй: ' + raw.slice(0, 200)); }
        else {
          let js = m[0];
          try { renderResult(JSON.parse(js)); }
          catch(e) {
            const lc = js.lastIndexOf(',"');
            js = lc > 0 ? js.slice(0, lc) + '}' : js + '}';
            try { renderResult(JSON.parse(js)); }
            catch(e2) { showError('Parse: ' + e2.message); }
          }
        }
      }
    } catch(e) { showError('Response: ' + e.message + ' | ' + xhr.responseText.slice(0,150)); }
    btn.disabled = false;
    btn.innerHTML = '🔍 AI ШИНЖЛЭХ';
  };

  xhr.onerror = function() { showError('Сүлжээний алдаа: ' + xhr.status); btn.disabled=false; btn.innerHTML='🔍 AI ШИНЖЛЭХ'; };
  xhr.ontimeout = function() { showError('Timeout — дахин оролдоно уу'); btn.disabled=false; btn.innerHTML='🔍 AI ШИНЖЛЭХ'; };
  xhr.send(payload);
}

