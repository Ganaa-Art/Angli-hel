  }
  $('winOutcomeBtn').disabled = true;
  $('loseOutcomeBtn').disabled = true;
}

// ── RENDER RESULT ───────────────────────────────────────
function renderResult(r){
  const isBuy = r.signal === 'BUY';
  const isSell = r.signal === 'SELL';
  const sc = isBuy ? 'var(--green)' : isSell ? 'var(--red)' : 'var(--gold)';

  $('signalText').textContent = isBuy ? '📈 BUY' : isSell ? '📉 SELL' : '⏳ WAIT';
  $('signalText').style.color = sc;
  $('pairText').textContent = r.pair + ' · ' + r.timeframe;
  $('confidenceText').textContent = r.confidence + '%';
  $('confidenceText').style.color = sc;
  $('rrText').textContent = 'R:R ' + r.rr_ratio;
  setTimeout(() => { $('confFill').style.width = Math.min(100, Number(r.confidence)||0) + '%'; }, 70);
  $('confFill').style.background = isBuy ? 'linear-gradient(90deg,var(--cyan),var(--green))' : isSell ? 'linear-gradient(90deg,var(--red),var(--pink))' : 'linear-gradient(90deg,var(--gold),var(--blue))';
  $('hero').style.borderColor = isBuy ? 'rgba(0,255,170,.25)' : isSell ? 'rgba(255,77,109,.24)' : 'rgba(255,204,0,.20)';

  $('winOutcomeBtn').disabled = false;
  $('loseOutcomeBtn').disabled = false;
  $('outcome-msg').style.display = 'none';
  $('outcome-msg').textContent = '';

  setTag($('signalBadge'), r.signal, isBuy?'ok':isSell?'bad':'mid');
  setTag($('dowTrendTag'), r.dow_trend, r.dow_trend==='BULLISH'?'ok':r.dow_trend==='BEARISH'?'bad':'mid');
  setTag($('dowStructTag'), r.dow_structure, r.dow_structure.includes('HH')?'ok':r.dow_structure.includes('LH')?'bad':'mid');
  setTag($('dowIntactTag'), r.dow_intact?'YES':'NO', r.dow_intact?'ok':'bad');
  setTag($('bearFvgTag'), r.fvg_bearish_count+' bearish', r.fvg_bearish_count>=3?'ok':'mid');
  setTag($('bullFvgTag'), r.fvg_bullish_count+' bullish', r.fvg_bullish_count>=1?'ok':'bad');
  setTag($('bosTag'), r.bos_detected?'YES':'NO', r.bos_detected?'ok':'bad');
  setTag($('chochTag'), r.choch_detected?'YES':'NO', r.choch_detected?'ok':'bad');
  setTag($('typeTag'), r.bos_choch_type, r.bos_choch_type!=='NONE'?'ok':'bad');
  setTag($('patternTag'), r.pattern_detected, r.pattern_detected!=='None'?'ok':'bad');
  setTag($('completeTag'), r.pattern_completion+'%', Number(r.pattern_completion)>=70?'ok':Number(r.pattern_completion)>=40?'mid':'bad');

  setPill($('dowPill'), r.dow_trend, r.dow_trend==='BULLISH'?'bull':r.dow_trend==='BEARISH'?'bear':'neu');
  setPill($('structPill'), r.dow_structure, r.dow_structure.includes('HH')?'bull':r.dow_structure.includes('LH')?'bear':'neu');
  setPill($('bosPill'), r.bos_choch_type+(r.bos_choch_direction!=='none'?' → '+r.bos_choch_direction:''), r.bos_choch_type==='CHOCH'?'bull':r.bos_choch_type==='BOS'?'neu':'bear');
  setPill($('patternPill'), r.pattern_detected, r.pattern_detected!=='None'?'bull':'neu');

  $('entryText').textContent = r.entry;
  $('slText').textContent = r.sl;
  $('srText').textContent = r.support_resistance;
  $('tp1Text').textContent = r.tp1;
  $('tp2Text').textContent = r.tp2;
  $('tp3Text').textContent = r.tp3;
  $('tfText').textContent = r.timeframe;
  $('reasonText').textContent = r.reasoning_mn || '';
  $('tgText').textContent = buildTelegram(r);

  $('result').style.display = 'flex';
  saveHistory(r);
  if(isBuy || isSell) setTimeout(() => launchConfetti(r.signal), 280);
  // Switch to signal tab
  switchTab('signal');
}

// ── ANALYZE ─────────────────────────────────────────────
async function analyze(){
  if(!b64){ showError('Зураг оруулна уу.'); return; }
  const key = $('api-key').value.trim();
  if(!key){ showError('Anthropic API key оруулна уу.'); return; }
  const btn = $('analyzeBtn');
  btn.disabled = true;
  btn.innerHTML = '<div class="spinner"></div> ШИНЖИЛЖ БАЙНА...';
  $('error-box').style.display = 'none';
  $('result').style.display = 'none';

  const payload = JSON.stringify({
    model:'claude-sonnet-4-5',
    max_tokens:2000,
    system:SYSTEM_PROMPT,
    messages:[{role:'user',content:[
      {type:'image',source:{type:'base64',media_type:'image/jpeg',data:b64}},
      {type:'text',text:'Analyze this XAUUSD chart. Return ONLY the JSON.'}
    ]}]
  });

  const xhr = new XMLHttpRequest();
  xhr.open('POST','https://gtrader-proxy.bayrmagnaiganerdene.workers.dev',true);
  xhr.setRequestHeader('Content-Type','application/json');
  xhr.setRequestHeader('x-api-key', key);
  xhr.setRequestHeader('anthropic-version','2023-06-01');
  xhr.timeout = 60000;

  xhr.onload = function(){
    try{
      const data = JSON.parse(xhr.responseText);
      if(data.error){
        showError('API: ' + (data.error.message || JSON.stringify(data.error)));
      } else {
        const raw = (data.content||[]).map(b => b.text||'').join('');
        const m = raw.match(/\{[\s\S]*\}/);
        if(!m){ showError('JSON олдсонгүй: ' + raw.slice(0,200)); }
        else {
          try { renderResult(JSON.parse(m[0])); }
          catch(err){
            const lc = m[0].lastIndexOf(',"');
            if(lc > 0){
              try { renderResult(JSON.parse(m[0].slice(0,lc)+'}')); }
              catch(e2){ showError('Parse: '+e2.message); }
            } else showError('Parse: '+err.message);
          }
        }
      }
    } catch(e){ showError('Response: '+e.message); }
    btn.disabled = false;
    btn.innerHTML = '🔍 AI ШИНЖЛЭХ';
  };
  xhr.onerror = function(){ showError('Сүлжээний алдаа'); btn.disabled=false; btn.innerHTML='🔍 AI ШИНЖЛЭХ'; };
  xhr.ontimeout = function(){ showError('Timeout'); btn.disabled=false; btn.innerHTML='🔍 AI ШИНЖЛЭХ'; };
  xhr.send(payload);
}

// ── EVENT LISTENERS ─────────────────────────────────────
