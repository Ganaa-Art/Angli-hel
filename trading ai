function buildTelegram(r){
  const icon = r.signal === 'BUY' ? '🟢' : r.signal === 'SELL' ? '🔴' : '🟡';
  const arrow = r.signal === 'BUY' ? '📈' : r.signal === 'SELL' ? '📉' : '⏳';
  const bos = r.choch_detected ? `CHOCH (${r.bos_choch_direction})` : r.bos_detected ? `BOS (${r.bos_choch_direction})` : 'Байхгүй';

  // Pip calculation (XAUUSD: 1 pip = 0.10)
  function pips(a, b) {
    const diff = Math.abs(parseFloat(a) - parseFloat(b));
    return isNaN(diff) ? '—' : (diff * 10).toFixed(0) + ' pip';
  }

  const slPips  = pips(r.entry, r.sl);
  const tp1Pips = pips(r.entry, r.tp1);
  const tp2Pips = pips(r.entry, r.tp2);
  const tp3Pips = pips(r.entry, r.tp3);

  return `${icon} G-TRADER SIGNAL ${icon}

${arrow} ${r.signal} — ${r.pair} | ${r.timeframe}
━━━━━━━━━━━━━━━━━━━━
📌 Орох:   ${r.entry}
🛑 SL:     ${r.sl}  (${slPips})
🎯 TP1:    ${r.tp1}  (+${tp1Pips})
🎯 TP2:    ${r.tp2}  (+${tp2Pips})
🎯 TP3:    ${r.tp3}  (+${tp3Pips})
⚖️ R:R =   ${r.rr_ratio}
━━━━━━━━━━━━━━━━━━━━
📊 Dow:    ${r.dow_trend} (${r.dow_structure})
🔲 FVG:    Bear ${r.fvg_bearish_count} | Bull ${r.fvg_bullish_count}
💥 BOS:    ${bos}
📐 H&S:    ${r.pattern_detected} (${r.pattern_completion}%)
🔒 Итгэл: ${r.confidence}%
━━━━━━━━━━━━━━━━━━━━
💡 ${r.reasoning_mn}

⚡️ @GTrader_FX`;
}

