<!DOCTYPE html>
<html lang="mn">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>G-Trader Pro — AI Signal Robot</title>
<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@500;600;700&family=JetBrains+Mono:wght@400;600;700&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#05070d;--bg2:#090d18;--panel:#0f1628;--panel2:#111a2f;
  --line:#1c2842;--text:#eaf3ff;--muted:#7f93b2;
  --cyan:#00fff0;--green:#00ffaa;--blue:#00ccff;
  --pink:#ff00bf;--gold:#ffcc00;--red:#ff4d6d;
  --shadow:0 0 24px rgba(0,255,240,.12),0 0 60px rgba(0,204,255,.06);
  --radius:18px;--font:'Rajdhani',sans-serif;--mono:'JetBrains Mono',monospace;
}
*{box-sizing:border-box;margin:0;padding:0}
html,body{min-height:100%}
body{
  font-family:var(--font);color:var(--text);overflow-x:hidden;
  background:radial-gradient(circle at 20% 10%,rgba(0,255,240,.08),transparent 22%),
    radial-gradient(circle at 80% 90%,rgba(255,0,191,.06),transparent 24%),
    linear-gradient(180deg,#04060b 0%,#080d17 100%);
}
body::before{
  content:"";position:fixed;inset:0;pointer-events:none;opacity:.45;
  background:linear-gradient(rgba(0,255,240,.035) 1px,transparent 1px),
    linear-gradient(90deg,rgba(0,255,240,.035) 1px,transparent 1px);
  background-size:48px 48px;
  mask-image:radial-gradient(circle at center,black 40%,transparent 100%);
}
body.light{--bg:#f0f4f8;--bg2:#e8eef5;--panel:#fff;--panel2:#f5f8fc;--line:#d0dbe8;--text:#1a2a3a;--muted:#5a7a98;background:#f0f4f8;}
body.light::before{opacity:.15;}
body.light header{background:rgba(240,244,248,.92);}
body.light .brand-txt h1{color:#0a1a2a;}
button,input{font:inherit}
a{color:inherit;text-decoration:none}

/* HEADER */
header{
  position:sticky;top:0;z-index:50;
  display:flex;align-items:center;justify-content:space-between;gap:12px;
  padding:12px 16px;background:rgba(5,7,13,.78);
  backdrop-filter:blur(18px);border-bottom:1px solid rgba(28,40,66,.9);
  box-shadow:0 8px 30px rgba(0,0,0,.22);
}
.brand{display:flex;align-items:center;gap:14px;min-width:0}
.logo{width:46px;height:46px;border-radius:50%;overflow:hidden;flex-shrink:0;border:2px solid rgba(0,255,240,.4);box-shadow:0 0 20px rgba(0,255,240,.3);}
.logo img{width:100%;height:100%;object-fit:cover;object-position:50% 15%;display:block;}
.brand-txt h1{font-size:20px;line-height:1;letter-spacing:4px;color:#fff;white-space:nowrap;}
.brand-txt p{margin-top:3px;font-family:var(--mono);font-size:9px;letter-spacing:2px;color:var(--muted);white-space:nowrap;}
.header-actions{display:flex;align-items:center;gap:10px;}
.badge{display:flex;align-items:center;gap:6px;padding:7px 12px;border-radius:999px;font-family:var(--mono);font-size:10px;letter-spacing:2px;border:1px solid rgba(0,255,240,.18);background:rgba(0,255,240,.06);color:var(--cyan);white-space:nowrap;}
.badge-dot{width:8px;height:8px;border-radius:50%;background:var(--green);box-shadow:0 0 10px var(--green);animation:pulse 1.8s infinite;}
.theme-btn{width:44px;height:44px;border-radius:14px;border:1px solid var(--line);background:linear-gradient(180deg,rgba(17,26,47,.95),rgba(10,14,25,.95));color:var(--text);cursor:pointer;transition:.25s;font-size:18px;}
.theme-btn:hover{transform:translateY(-1px);border-color:rgba(0,255,240,.4);color:var(--cyan)}

/* MAIN */
main{position:relative;z-index:1;width:min(1080px,calc(100% - 28px));margin:22px auto 110px;display:grid;gap:16px;}

/* TAB PANELS */
.tab-panel{display:none}
.tab-panel.active{display:grid;gap:16px}

/* SECTION TITLE */
.section-title{display:flex;align-items:center;gap:12px;font-family:var(--mono);font-size:10px;letter-spacing:4px;color:var(--muted);margin:4px 2px 2px;}
.section-title::after{content:"";height:1px;flex:1;background:linear-gradient(90deg,rgba(0,255,240,.35),transparent);}

/* GRID */
.grid-4{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;}

/* CARD */
.card{background:linear-gradient(180deg,rgba(17,26,47,.92),rgba(10,14,25,.96));border:1px solid rgba(28,40,66,.95);border-radius:var(--radius);box-shadow:var(--shadow);overflow:hidden;}
body.light .card{background:var(--panel);border-color:var(--line);box-shadow:0 2px 16px rgba(0,0,0,.08);}

/* STRATEGY */
.strategy{padding:20px 14px;text-align:center;transition:.25s;position:relative;}
.strategy:hover{transform:translateY(-2px);border-color:rgba(0,255,240,.35);}
.strategy .icon{font-size:22px;margin-bottom:8px}
.strategy .small{font-family:var(--mono);font-size:9px;letter-spacing:2px;color:var(--muted);margin-bottom:6px}
.strategy .big{font-size:15px;font-weight:700;color:#fff}
body.light .strategy .big{color:var(--text);}

/* UPLOAD */
.upload{padding:18px;}
.upload-box{border:1.5px dashed rgba(0,255,240,.25);border-radius:22px;min-height:220px;background:linear-gradient(180deg,rgba(9,13,24,.92),rgba(7,10,18,.94));display:flex;align-items:center;justify-content:center;overflow:hidden;cursor:pointer;transition:.25s;}
body.light .upload-box{background:var(--bg2);border-color:var(--line);}
.upload-box:hover,.upload-box.drag{border-color:rgba(0,255,240,.6);}
.upload-inner{text-align:center;padding:24px}
.upload-ico{font-size:44px;margin-bottom:12px}
.upload-title{font-size:24px;font-weight:700;color:#fff;letter-spacing:1px}
body.light .upload-title{color:var(--text);}
.upload-sub{margin-top:6px;font-family:var(--mono);font-size:11px;color:var(--muted);letter-spacing:1.4px}
#preview{width:100%;height:auto;display:none;object-fit:contain;}
#file-input{display:none}

/* API */
.api{padding:18px;}
.api label{display:block;margin-bottom:10px;font-family:var(--mono);font-size:10px;letter-spacing:4px;color:var(--muted)}
.api-input{width:100%;padding:14px 16px;border-radius:14px;border:1px solid rgba(28,40,66,.95);background:#080d17;color:var(--text);outline:none;font-family:var(--mono);font-size:12px;transition:.25s;}
body.light .api-input{background:var(--bg2);border-color:var(--line);color:var(--text);}
.api-input:focus{border-color:rgba(0,255,240,.5);box-shadow:0 0 0 4px rgba(0,255,240,.06);}
.api-hint{margin-top:10px;font-family:var(--mono);font-size:10px;color:var(--muted);}

/* BUTTONS */
.btn-row{display:flex;gap:10px;flex-wrap:wrap;}
.btn{border:none;cursor:pointer;transition:.25s;border-radius:14px;font-weight:700;}
.btn-analyze{flex:1;min-height:54px;display:flex;align-items:center;justify-content:center;gap:10px;padding:14px 18px;font-size:16px;letter-spacing:2px;color:#02110f;background:linear-gradient(135deg,var(--cyan),var(--green),var(--blue));box-shadow:0 10px 30px rgba(0,255,240,.18);}
.btn-analyze:hover:not(:disabled){transform:translateY(-2px);filter:saturate(1.2);}
.btn-analyze:disabled{cursor:default;opacity:.7;filter:grayscale(.2);}
.btn-clear{width:54px;height:54px;background:linear-gradient(180deg,rgba(17,26,47,.96),rgba(9,13,24,.96));border:1px solid rgba(28,40,66,.95);color:var(--muted);font-size:18px;}
.btn-clear:hover{color:var(--red);border-color:rgba(255,77,109,.4)}
.spinner{width:18px;height:18px;border-radius:50%;border:2px solid rgba(2,17,15,.24);border-top-color:#02110f;animation:spin .7s linear infinite;}

/* ERROR */
#error-box{display:none;padding:14px 16px;border-radius:16px;background:rgba(255,77,109,.08);border:1px solid rgba(255,77,109,.24);color:#ff8ca0;font-family:var(--mono);font-size:12px;line-height:1.7;}

/* RESULT */
#result{display:none;flex-direction:column;gap:16px;animation:fadeUp .35s ease;}

/* HERO */
.hero{position:relative;overflow:hidden;border-radius:24px;padding:24px;background:linear-gradient(180deg,rgba(17,26,47,.98),rgba(7,10,18,.98));border:1px solid rgba(0,255,240,.18);}
.hero-top{display:flex;justify-content:space-between;gap:16px;align-items:flex-start;flex-wrap:wrap;}
.signal{font-size:54px;line-height:1;letter-spacing:4px;font-weight:800;}
.signal-sub{margin-top:10px;font-family:var(--mono);font-size:11px;letter-spacing:2px;color:var(--muted);}
.conf{text-align:right;min-width:140px;}
.conf-label{font-family:var(--mono);font-size:10px;letter-spacing:3px;color:var(--muted)}
.conf-num{margin-top:6px;font-size:46px;font-weight:800;line-height:1;}
.rr{margin-top:8px;font-family:var(--mono);font-size:11px;color:var(--muted);}
.track{margin-top:18px;height:5px;border-radius:999px;background:rgba(255,255,255,.06);overflow:hidden;}
.fill{width:0%;height:100%;border-radius:inherit;transition:width 1.2s cubic-bezier(.22,1,.36,1);}
.outcome-hero{display:flex;gap:10px;margin-top:16px;}
.outcome-hero-btn{flex:1;padding:12px;border-radius:12px;border:1px solid;font-family:var(--font);font-size:15px;font-weight:700;cursor:pointer;letter-spacing:1px;transition:.2s;background:transparent;}
.outcome-hero-btn:hover{transform:translateY(-1px);}
.outcome-hero-btn.win{color:var(--green);border-color:rgba(0,255,170,.3);background:rgba(0,255,170,.08);}
.outcome-hero-btn.lose{color:var(--red);border-color:rgba(255,77,109,.3);background:rgba(255,77,109,.08);}
.outcome-hero-btn:disabled{opacity:.4;cursor:default;transform:none;}
#outcome-msg{display:none;text-align:center;padding:10px;font-family:var(--mono);font-size:12px;margin-top:8px;border-radius:10px;}

/* CARD HEAD */
.card-head{padding:14px 16px;border-bottom:1px solid rgba(28,40,66,.9);display:flex;align-items:center;justify-content:space-between;gap:10px;font-family:var(--mono);font-size:10px;letter-spacing:4px;color:var(--muted)}
body.light .card-head{border-color:var(--line);}

/* ANALYSIS */
.analysis-grid{display:grid;grid-template-columns:1fr 1fr;}
.analysis-col{padding:16px;}
.analysis-col:first-child{border-right:1px solid rgba(28,40,66,.9);}
body.light .analysis-col:first-child{border-color:var(--line);}
.analysis-label{margin-bottom:12px;font-family:var(--mono);font-size:10px;letter-spacing:3px;color:var(--muted);}
.row{display:flex;align-items:center;justify-content:space-between;gap:12px;padding:9px 0;border-bottom:1px solid rgba(255,255,255,.04);}
.row:last-child{border-bottom:none}
.name{font-size:14px;font-weight:700;color:#fff}
body.light .name{color:var(--text);}
.tag{font-family:var(--mono);font-size:11px;padding:4px 10px;border-radius:999px;border:1px solid transparent;white-space:nowrap;}
.ok{background:rgba(0,255,170,.10);color:var(--green);border-color:rgba(0,255,170,.18)}
.bad{background:rgba(255,77,109,.09);color:var(--red);border-color:rgba(255,77,109,.18)}
.mid{background:rgba(255,204,0,.09);color:var(--gold);border-color:rgba(255,204,0,.18)}
.dow-tags{display:flex;flex-wrap:wrap;gap:8px;padding:0 16px 16px;}
.pill{padding:6px 12px;border-radius:999px;font-family:var(--mono);font-size:10px;font-weight:700;letter-spacing:1px;border:1px solid rgba(28,40,66,.95);background:rgba(255,255,255,.03)}
.bull{color:var(--green);border-color:rgba(0,255,170,.20);background:rgba(0,255,170,.08)}
.bear{color:var(--red);border-color:rgba(255,77,109,.22);background:rgba(255,77,109,.08)}
.neu{color:var(--gold);border-color:rgba(255,204,0,.18);background:rgba(255,204,0,.08)}

/* LEVELS */
.levels{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:rgba(28,40,66,.95);}
body.light .levels{background:var(--line);}
.level{background:linear-gradient(180deg,rgba(17,26,47,.96),rgba(9,13,24,.98));padding:14px 12px;}
body.light .level{background:var(--panel);}
.level-lbl{font-family:var(--mono);font-size:8px;letter-spacing:3px;color:var(--muted);margin-bottom:6px}
.level-val{font-family:var(--mono);font-size:15px;font-weight:700;}

/* REASON */
.reason{padding:16px;font-size:15px;line-height:1.9;color:#d7e8ff;}
body.light .reason{color:var(--text);}

/* TELEGRAM */
.tg{padding:16px;}
.tg-top{display:flex;align-items:center;justify-content:space-between;gap:10px;padding-bottom:12px;}
.copy-btn{border:none;border-radius:12px;padding:8px 14px;cursor:pointer;background:rgba(0,255,240,.10);color:var(--cyan);border:1px solid rgba(0,255,240,.20);font-family:var(--mono);font-size:10px;letter-spacing:2px;}
.copy-btn:hover{background:rgba(0,255,240,.16)}
.tg-body{font-family:var(--mono);font-size:11px;line-height:1.9;white-space:pre-wrap;color:#9eb4d4;max-height:260px;overflow:auto;}
body.light .tg-body{color:var(--muted);}

/* WIN RATE */
.wr{padding:16px;}
.wr-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;}
.wr-cell{padding:14px 10px;text-align:center;border-radius:16px;border:1px solid rgba(28,40,66,.95);background:rgba(255,255,255,.03);}
body.light .wr-cell{background:var(--bg2);border-color:var(--line);}
.wr-num{font-size:28px;font-weight:800;line-height:1;margin-bottom:4px}
.wr-lbl{font-family:var(--mono);font-size:9px;letter-spacing:2px;color:var(--muted)}
.wr-bar-track{margin-top:14px;height:7px;border-radius:999px;background:rgba(255,255,255,.06);overflow:hidden;}
body.light .wr-bar-track{background:var(--line);}
.wr-bar-fill{height:100%;width:0%;border-radius:inherit;background:linear-gradient(90deg,var(--cyan),var(--green),var(--blue));transition:width .8s ease;}
.outcome-btns{display:flex;gap:10px;margin-top:12px;}
.outcome-btn{flex:1;border-radius:14px;padding:12px;border:1px solid rgba(28,40,66,.95);background:linear-gradient(180deg,rgba(17,26,47,.96),rgba(9,13,24,.98));color:var(--text);cursor:pointer;font-family:var(--font);font-weight:700;letter-spacing:1px;}
body.light .outcome-btn{background:var(--bg2);border-color:var(--line);}
.win{color:var(--green);border-color:rgba(0,255,170,.18)}
.lose{color:var(--red);border-color:rgba(255,77,109,.18)}
.reset{color:var(--muted)}
.outcome-btn:hover{transform:translateY(-1px)}

/* HISTORY */
.history{padding:16px;}
.history-list{display:grid;gap:10px;}
.history-item{padding:14px 16px;border-radius:16px;border:1px solid rgba(28,40,66,.95);background:rgba(255,255,255,.03);display:flex;justify-content:space-between;gap:14px;align-items:center;}
body.light .history-item{background:var(--bg2);border-color:var(--line);}
.history-signal{font-size:18px;font-weight:800}
.history-meta{margin-top:4px;font-family:var(--mono);font-size:10px;color:var(--muted);}
.history-right{text-align:right;font-family:var(--mono);font-size:11px;color:#b8c7de;}
body.light .history-right{color:var(--text);}

/* BOTTOM NAV */
.bottom-nav{position:fixed;left:0;right:0;bottom:0;z-index:40;display:flex;justify-content:space-around;align-items:center;padding:10px 12px 14px;border-top:1px solid rgba(28,40,66,.95);background:rgba(5,7,13,.82);backdrop-filter:blur(18px);}
body.light .bottom-nav{background:rgba(240,244,248,.92);border-color:var(--line);}
.nav-item{flex:1;border:none;background:none;color:var(--muted);display:flex;flex-direction:column;align-items:center;gap:4px;cursor:pointer;padding:6px 10px;border-radius:14px;}
.nav-item:hover{background:rgba(0,255,240,.06)}
.nav-item.active{color:var(--cyan);background:rgba(0,255,240,.08);}
body.light .nav-item.active{color:var(--blue);}
.nav-icon{font-size:20px;line-height:1}
.nav-label{font-family:var(--mono);font-size:9px;letter-spacing:1px}

/* CONFETTI */
.confetti{position:fixed;top:-12px;width:10px;height:10px;border-radius:2px;pointer-events:none;z-index:9999;animation:fall linear forwards;}

/* EMPTY STATE */
.empty-state{padding:40px 20px;text-align:center;color:var(--muted);font-family:var(--mono);font-size:12px;}
.empty-state .empty-ico{font-size:40px;margin-bottom:12px;opacity:.5;}

@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.35;transform:scale(.8)}}
@keyframes spin{to{transform:rotate(360deg)}}
@keyframes fadeUp{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:translateY(0)}}
@keyframes fall{to{transform:translateY(110vh) rotate(720deg);opacity:0}}
@media(max-width:900px){.grid-4{grid-template-columns:repeat(2,1fr)}.analysis-grid{grid-template-columns:1fr}.analysis-col:first-child{border-right:none;border-bottom:1px solid rgba(28,40,66,.9)}.levels{grid-template-columns:repeat(2,1fr)}}
@media(max-width:600px){header{padding:12px 14px}.brand-txt h1{font-size:20px;letter-spacing:4px}.signal{font-size:40px}.conf-num{font-size:34px}.hero{padding:18px}.grid-4{grid-template-columns:1fr 1fr}.levels{grid-template-columns:1fr 1fr}.wr-grid{grid-template-columns:1fr}}
</style>
</head>
<body>

<header>
  <div class="brand">
    <div class="logo">
      <img src="data:image/jpeg;base64," alt="G-Trader">
    </div>
    <div class="brand-txt">
      <h1>G-TRADER</h1>
      <p>DOW · FVG · BOS/CHOCH · H&S</p>
    </div>
  </div>
  <div class="header-actions">
    <div class="badge"><span class="badge-dot"></span>AI LIVE</div>
    <button class="theme-btn" id="themeBtn">🌙</button>
  </div>
</header>

<main>

  <!-- ══════ SIGNAL TAB ══════ -->
  <div class="tab-panel active" id="tab-signal">
    <div class="section-title">СТРАТЕГИ</div>
    <div class="grid-4">
      <div class="card strategy"><div class="icon">📈</div><div class="small">DOW THEORY</div><div class="big">HH/HL · LH/LL</div></div>
      <div class="card strategy"><div class="icon">🔲</div><div class="small">FVG</div><div class="big">Fair Value Gap</div></div>
      <div class="card strategy"><div class="icon">💥</div><div class="small">BOS / CHOCH</div><div class="big">Structure Shift</div></div>
      <div class="card strategy"><div class="icon">📐</div><div class="small">H&S</div><div class="big">Pattern Detect</div></div>
    </div>

    <div class="section-title">CHART ЗУРАГ</div>
    <div class="card upload">
      <div id="drop-zone" class="upload-box">
        <div class="upload-inner" id="placeholder">
          <div class="upload-ico">📊</div>
          <div class="upload-title">Chart зураг оруулна уу</div>
          <div class="upload-sub">TradingView screenshot — drag & drop эсвэл дарна уу</div>
        </div>
        <img id="preview" alt="Preview">
      </div>
      <input type="file" id="file-input" accept="image/*">
    </div>

    <div class="card api">
      <label>ANTHROPIC API KEY</label>
      <input type="password" id="api-key" class="api-input" placeholder="sk-ant-api03-...">
      <div class="api-hint">🔑 console.anthropic.com → API Keys → Create Key</div>
    </div>

    <div class="btn-row" id="btn-row" style="display:none">
      <button class="btn btn-analyze" id="analyzeBtn">🔍 AI ШИНЖЛЭХ</button>
      <button class="btn btn-clear" id="clearAllBtn">✕</button>
    </div>

    <div id="error-box"></div>

    <div id="result">
      <div class="hero" id="hero">
        <div class="hero-top">
          <div>
            <div class="signal" id="signalText">WAIT</div>
            <div class="signal-sub" id="pairText">XAUUSD · —</div>
          </div>
          <div class="conf">
            <div class="conf-label">ИТГЭЛЦҮҮР</div>
            <div class="conf-num" id="confidenceText">0%</div>
            <div class="rr" id="rrText">R:R —</div>
          </div>
        </div>
        <div class="track"><div class="fill" id="confFill"></div></div>
        <div class="outcome-hero">
          <button class="outcome-hero-btn win" id="winOutcomeBtn">✅ ЯЛСАН</button>
          <button class="outcome-hero-btn lose" id="loseOutcomeBtn">❌ ЯЛАГДСАН</button>
        </div>
        <div id="outcome-msg"></div>
      </div>

      <div class="card">
        <div class="card-head"><span>ДҮН ШИНЖИЛГЭЭ</span><span id="signalBadge" class="tag mid">WAIT</span></div>
        <div class="analysis-grid">
          <div class="analysis-col">
            <div class="analysis-label">DOW THEORY + FVG</div>
            <div class="row"><span class="name">Trend</span><span class="tag mid" id="dowTrendTag">—</span></div>
            <div class="row"><span class="name">Structure</span><span class="tag mid" id="dowStructTag">—</span></div>
            <div class="row"><span class="name">Trend Intact</span><span class="tag mid" id="dowIntactTag">—</span></div>
            <div class="row"><span class="name">Bearish FVG</span><span class="tag mid" id="bearFvgTag">—</span></div>
            <div class="row"><span class="name">Bullish FVG</span><span class="tag mid" id="bullFvgTag">—</span></div>
          </div>
